// ── STATE ─────────────────────────────────────────────────────────────────
let currentMode = 'browse';
let fcUnits = ['u1'];
let fcCards = [];
let fcIndex = 0;
let fcFlipped = false;

let quizUnits = ['u9','u10'];
let quizCards = [];
let quizIndex = 0;
let quizScore = 0;
let quizAnswered = null;
let quizDone = false;

// ── UTILS ─────────────────────────────────────────────────────────────────
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length-1; i > 0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

function getAllPhrases(unitIds) {
  return unitIds.flatMap(id => {
    const u = UNITS.find(u => u.id === id);
    return u ? u.phrases.map(p => ({...p, unitName: u.name, unitNum: u.num})) : [];
  });
}

// ── BROWSE MODE ───────────────────────────────────────────────────────────
function scrollToUnit(id) {
  document.getElementById('browse-mode').style.display = 'block';
  document.getElementById('flashcard-mode').style.display = 'none';
  document.getElementById('quiz-mode').style.display = 'none';
  document.getElementById('search-results').style.display = 'none';
  document.getElementById('search-input').value = '';
  setMode('browse');
  setTimeout(() => {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({behavior:'smooth', block:'start'});
  }, 50);
  document.querySelectorAll('.nav-item').forEach((b,i) => b.classList.remove('active'));
  const units = ['u1','u2','u3','u4','u5','u6','u8','u9','u10','u11','u12'];
  const idx = units.indexOf(id);
  if (idx >= 0) document.querySelectorAll('.nav-item')[idx].classList.add('active');
}

function toggleHighlight(el) {
  el.classList.toggle('highlighted');
}

// ── SEARCH ────────────────────────────────────────────────────────────────
function handleSearch(q) {
  const sr = document.getElementById('search-results');
  const bm = document.getElementById('browse-mode');
  const fm = document.getElementById('flashcard-mode');
  const qm = document.getElementById('quiz-mode');
  if (!q.trim()) {
    sr.style.display = 'none';
    if (currentMode === 'browse') bm.style.display = 'block';
    else if (currentMode === 'flashcard') fm.style.display = 'block';
    else qm.style.display = 'block';
    return;
  }
  bm.style.display = 'none';
  fm.style.display = 'none';
  qm.style.display = 'none';
  sr.style.display = 'block';
  const term = q.toLowerCase();
  const results = [];
  UNITS.forEach(u => {
    u.phrases.forEach(ph => {
      if (ph.p.toLowerCase().includes(term) || ph.cat.toLowerCase().includes(term)) {
        results.push({phrase:ph.p, cat:ph.cat, unit:`Unit ${u.num} – ${u.name}`});
      }
    });
  });
  if (!results.length) {
    sr.innerHTML = `<div class="no-results">Keine Phrasen gefunden für „${q}"</div>`;
    return;
  }
  const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
  sr.innerHTML = `<div style="font-size:13px;color:var(--ink-light);margin-bottom:1rem;">${results.length} Ergebnis${results.length!==1?'se':''} für „${q}"</div>` +
    results.map(r => `<div class="search-result-item">
      <div class="search-result-phrase">${r.phrase.replace(re,'<mark>$1</mark>')}</div>
      <div class="search-result-meta">${r.cat} · ${r.unit}</div>
    </div>`).join('');
}

// ── MODE SWITCH ───────────────────────────────────────────────────────────
function setMode(mode) {
  currentMode = mode;
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.mode-btn')[['browse','flashcard','quiz'].indexOf(mode)].classList.add('active');
  document.getElementById('browse-mode').style.display = mode==='browse' ? 'block' : 'none';
  document.getElementById('flashcard-mode').style.display = mode==='flashcard' ? 'block' : 'none';
  document.getElementById('quiz-mode').style.display = mode==='quiz' ? 'block' : 'none';
  document.getElementById('search-results').style.display = 'none';
  document.getElementById('search-input').value = '';
  if (mode==='flashcard') initFlashcards();
  if (mode==='quiz') initQuiz();
}

// ── FLASHCARDS ────────────────────────────────────────────────────────────
function initFlashcards() {
  buildFcUnitSelect();
  buildFcDeck();
}

function buildFcUnitSelect() {
  const el = document.getElementById('fc-unit-select');
  el.innerHTML = UNITS.map(u =>
    `<button class="fc-unit-btn ${fcUnits.includes(u.id)?'active':''}"
      onclick="toggleFcUnit('${u.id}')">${u.num}. ${u.name}</button>`
  ).join('');
}

function toggleFcUnit(id) {
  if (fcUnits.includes(id)) {
    if (fcUnits.length === 1) return;
    fcUnits = fcUnits.filter(u => u !== id);
  } else {
    fcUnits.push(id);
  }
  buildFcUnitSelect();
  buildFcDeck();
}

function buildFcDeck() {
  fcCards = getAllPhrases(fcUnits);
  fcIndex = 0;
  fcFlipped = false;
  renderFcCard();
}

function renderFcCard() {
  if (!fcCards.length) return;
  const card = fcCards[fcIndex];
  document.getElementById('fc-inner').classList.toggle('flipped', fcFlipped);
  document.getElementById('fc-category').textContent = card.cat;
  document.getElementById('fc-phrase').textContent = card.p;
  const pct = Math.round(fcIndex / fcCards.length * 100);
  document.getElementById('fc-pbar').style.width = pct + '%';
  document.getElementById('fc-ptext').textContent = `${fcIndex+1} / ${fcCards.length}`;
  document.getElementById('fc-prev').disabled = fcIndex === 0;
  document.getElementById('fc-next').disabled = fcIndex === fcCards.length - 1;
}

function flipCard() {
  fcFlipped = !fcFlipped;
  document.getElementById('fc-inner').classList.toggle('flipped', fcFlipped);
}

function fcNav(dir) {
  fcIndex = Math.max(0, Math.min(fcCards.length-1, fcIndex+dir));
  fcFlipped = false;
  renderFcCard();
}

function fcShuffle() {
  fcCards = shuffle(fcCards);
  fcIndex = 0;
  fcFlipped = false;
  renderFcCard();
}

// ── QUIZ ──────────────────────────────────────────────────────────────────
function initQuiz() {
  buildQuizUnitSelect();
  buildQuizDeck();
}

function buildQuizUnitSelect() {
  const el = document.getElementById('quiz-unit-select');
  el.innerHTML = UNITS.map(u =>
    `<button class="fc-unit-btn ${quizUnits.includes(u.id)?'active':''}"
      onclick="toggleQuizUnit('${u.id}')">${u.num}. ${u.name}</button>`
  ).join('');
}

function toggleQuizUnit(id) {
  if (quizUnits.includes(id)) {
    if (quizUnits.length === 1) return;
    quizUnits = quizUnits.filter(u => u !== id);
  } else {
    quizUnits.push(id);
  }
  buildQuizUnitSelect();
  buildQuizDeck();
}

function buildQuizDeck() {
  quizCards = shuffle(getAllPhrases(quizUnits));
  quizIndex = 0;
  quizScore = 0;
  quizAnswered = null;
  quizDone = false;
  renderQuiz();
}

function renderQuiz() {
  const el = document.getElementById('quiz-content');
  if (quizDone || quizIndex >= quizCards.length) {
    const total = Math.min(quizCards.length, quizIndex);
    const pct = total > 0 ? Math.round(quizScore/total*100) : 0;
    const color = pct>=80?'var(--teal)':pct>=50?'var(--gold)':'var(--red)';
    el.innerHTML = `<div class="q-done">
      <div class="q-done-score">${quizScore}</div>
      <div class="q-done-total">von ${total} richtig</div>
      <div class="q-done-bar"><div class="q-done-fill" style="width:${pct}%;background:${color}"></div></div>
      <div class="q-done-label">${pct}% – ${pct>=80?'Ausgezeichnet!':pct>=50?'Gut gemacht!':'Weiter üben!'}</div>
      <button class="fc-btn primary" onclick="buildQuizDeck()">Nochmal versuchen</button>
    </div>`;
    return;
  }
  const card = quizCards[quizIndex];
  const pct = Math.round(quizIndex / quizCards.length * 100);
  const allCats = [...new Set(getAllPhrases(quizUnits).map(c => c.cat))];
  const wrongCats = shuffle(allCats.filter(c => c !== card.cat)).slice(0,3);
  const opts = shuffle([card.cat, ...wrongCats]);
  const letters = ['A','B','C','D'];

  el.innerHTML = `
    <div class="q-progress">
      <div class="q-bar"><div class="q-fill" style="width:${pct}%"></div></div>
      <span class="q-text">${quizIndex+1} / ${quizCards.length}</span>
      <span class="q-score-badge">${quizScore} Punkte</span>
    </div>
    <div class="q-question">
      <div class="q-unit-tag">Unit ${card.unitNum} – ${card.unitName}</div>
      <div class="q-phrase">"${card.p}"</div>
    </div>
    <div class="q-options">
      ${opts.map((opt,i) => `
        <button class="q-opt" id="qopt${i}" onclick="answerQuiz('${opt.replace(/'/g,"\\'")}','${card.cat.replace(/'/g,"\\'")}',${i})">
          <span class="opt-letter">${letters[i]}</span>${opt}
        </button>`).join('')}
    </div>
    <div class="q-next-row" id="q-next-row" style="display:none">
      <span id="q-feedback" style="font-size:14px;font-weight:500;"></span>
      <button class="fc-btn primary" onclick="nextQuiz()">Weiter →</button>
    </div>`;
}

function answerQuiz(chosen, correct, idx) {
  if (quizAnswered !== null) return;
  quizAnswered = chosen;
  document.querySelectorAll('.q-opt').forEach(b => b.disabled = true);
  const isCorrect = chosen === correct;
  if (isCorrect) quizScore++;
  document.querySelectorAll('.q-opt').forEach(b => {
    const text = b.textContent.trim().slice(1).trim();
    if (text === correct) b.classList.add('correct');
    else if (text === chosen && !isCorrect) b.classList.add('wrong');
  });
  const row = document.getElementById('q-next-row');
  const fb = document.getElementById('q-feedback');
  fb.textContent = isCorrect ? '✓ Richtig!' : `✗ Richtig wäre: ${correct}`;
  fb.style.color = isCorrect ? 'var(--teal)' : 'var(--red)';
  row.style.display = 'flex';
}

function nextQuiz() {
  quizIndex++;
  quizAnswered = null;
  if (quizIndex >= quizCards.length) quizDone = true;
  renderQuiz();
}

// ── INIT ──────────────────────────────────────────────────────────────────
window.addEventListener('scroll', () => {
  const units = ['u1','u2','u3','u4','u5','u6','u8','u9','u10','u11','u12'];
  const navItems = document.querySelectorAll('.nav-item');
  if (currentMode !== 'browse') return;
  for (let i = units.length-1; i >= 0; i--) {
    const el = document.getElementById(units[i]);
    if (el && el.getBoundingClientRect().top <= 120) {
      navItems.forEach(b => b.classList.remove('active'));
      navItems[i].classList.add('active');
      break;
    }
  }
});
